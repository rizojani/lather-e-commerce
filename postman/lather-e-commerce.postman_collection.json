        {
          "name": "Products",
          "item": [
            {
              "name": "List Products (paginated + filters)",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
                "url": {
                  "raw": "{{baseUrl}}/admin/products?page=1&limit=10",
                  "host": ["{{baseUrl}}"],
                  "path": ["admin", "products"],
                  "query": [
                    { "key": "page", "value": "1", "description": "Optional; default 1" },
                    { "key": "limit", "value": "10", "description": "Optional; default 10, max 100" },
                    {
                      "key": "search",
                      "value": "jacket",
                      "disabled": true,
                      "description": "Matches title, legacy name, or category name (substring)"
                    },
                    {
                      "key": "status",
                      "value": "active",
                      "disabled": true,
                      "description": "active | inactive"
                    },
                    {
                      "key": "inventoryStatus",
                      "value": "in-stock",
                      "disabled": true,
                      "description": "in-stock | out-of-stock"
                    },
                    {
                      "key": "fromDate",
                      "value": "2025-01-01",
                      "disabled": true,
                      "description": "createdAt >= start of day UTC"
                    },
                    {
                      "key": "toDate",
                      "value": "2025-12-31",
                      "disabled": true,
                      "description": "createdAt <= end of day UTC"
                    },
                    {
                      "key": "categoryIds[0]",
                      "value": "{{categoryId}}",
                      "disabled": true,
                      "description": "Bracket style; add categoryIds[1], categoryIds[2], … for more ids"
                    },
                    {
                      "key": "categoryIds[1]",
                      "value": "",
                      "disabled": true,
                      "description": "Second category id (optional)"
                    }
                  ]
                },
                "description": "GET /admin/products. Optional filters. categoryIds: use categoryIds[0], categoryIds[1], … or repeat categoryIds / comma-separated / JSON array string."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "let jsonData = {};",
                      "try { jsonData = pm.response.json(); } catch (e) {}",
                      "const d = jsonData?.data;",
                      "pm.test('List products returns paginated shape', function () {",
                      "  pm.expect(pm.response.code).to.equal(200);",
                      "  pm.expect(d).to.be.an('object');",
                      "  pm.expect(d?.items).to.be.an('array');",
                      "  pm.expect(d?.meta).to.be.an('object');",
                      "  pm.expect(d?.meta?.total).to.be.a('number');",
                      "});"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Create Product (multipart)",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    {
                      "key": "categoryId",
                      "value": "{{categoryId}}",
                      "type": "text",
                      "description": "Run Admin > List Categories first, or paste a category Mongo id"
                    },
                    { "key": "title", "value": "Summer Jacket", "type": "text" },
                    {
                      "key": "description",
                      "value": "<p>Gentle <strong>HTML</strong> description from editor</p>",
                      "type": "text"
                    },
                    { "key": "inventoryStatus", "value": "in-stock", "type": "text" },
                    { "key": "status", "value": "active", "type": "text" },
                    { "key": "price", "value": "99.99", "type": "text" },
                    { "key": "hasDiscount", "value": "true", "type": "text" },
                    { "key": "discountInPercentage", "value": "10", "type": "text" },
                    {
                      "key": "medias",
                      "description": "Repeat this row to attach multiple images/videos",
                      "type": "file",
                      "src": "",
                      "disabled": true
                    },
                    {
                      "key": "medias",
                      "type": "file",
                      "src": "",
                      "disabled": true
                    }
                  ]
                },
                "url": "{{baseUrl}}/admin/products",
                "description": "Required when hasDiscount is true: discountInPercentage (0–100). Omit medias rows or enable file rows to upload. Response data includes nested category and medias (ProductResource.adminDetail)."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "let jsonData = {};",
                      "try { jsonData = pm.response.json(); } catch (e) {}",
                      "const id = jsonData?.data?.id;",
                      "if (id) {",
                      "  pm.collectionVariables.set('productId', id);",
                      "  pm.test('productId saved from create', function () {",
                      "    pm.expect(id).to.be.a('string').and.not.empty;",
                      "  });",
                      "}",
                      "pm.test('Create product returns nested category and medias', function () {",
                      "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                      "  pm.expect(jsonData?.data?.category).to.exist;",
                      "  pm.expect(jsonData?.data?.medias).to.be.an('array');",
                      "});"
                    ]
                  }
                }
              ]
