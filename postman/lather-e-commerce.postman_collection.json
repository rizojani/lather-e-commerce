                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
                "url": "{{baseUrl}}/admin/products/{{productId}}",
                "description": "Same response shape as create/update: nested category + medias. Includes inactive products. Set {{productId}} from create or list."
              }
            },
            {
              "name": "Update Product (multipart)",
              "request": {
                "method": "PATCH",
                "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    { "key": "title", "value": "Updated title", "type": "text", "disabled": true },
                    { "key": "description", "value": "<p>Updated HTML</p>", "type": "text", "disabled": true },
                    { "key": "price", "value": "89.99", "type": "text", "disabled": true },
                    { "key": "hasDiscount", "value": "false", "type": "text", "disabled": true },
                    {
                      "key": "deleteMediaIds",
                      "value": "[\"paste-media-object-id-here\"]",
                      "type": "text",
                      "disabled": true,
                      "description": "JSON array or use deleteMediaIds[0]=id style — only ids already on this product"
                    },
                    {
                      "key": "medias",
                      "type": "file",
                      "src": "",
                      "disabled": true,
                      "description": "Append new images/videos"
                    }
                  ]
                },
                "url": "{{baseUrl}}/admin/products/{{productId}}",
                "description": "All parts optional. Enable fields to patch. Response same shape as create (category + medias). Remove Content-Type header so Postman sets multipart boundary."
              }
            },
            {
              "name": "Delete Product",
              "request": {
                "method": "DELETE",
                "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
                "url": "{{baseUrl}}/admin/products/{{productId}}"
              }
            }
          ]
        },
        {
          "name": "Orders",
          "item": [
            {
              "name": "List Orders (Paginated + Filters)",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
                "url": "{{baseUrl}}/admin/orders?page=1&limit=10&search=&status=&fromDate=&toDate=&paymentStatus=&userId=",
                "description": "Paginated admin orders with optional filters. Empty query values are ignored by backend. Search matches user name/email, product title/name, and category name. Each row includes items, user, and paymentLog."
              }
            },
            {
              "name": "Get Order By Id",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
                "url": "{{baseUrl}}/admin/orders/{{orderId}}",
                "description": "Admin detail response with OrderResource.adminOne shape: items with product/category/medias, embedded user, and paymentLog."
              }
            },
            {
              "name": "Patch Order (Status + Reason)",
              "request": {
                "method": "PATCH",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{admin_token}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"status\": \"processing\",\n  \"reason\": \"Required only when status is cancelled or rejected\"\n}"
                },
                "url": "{{baseUrl}}/admin/orders/{{orderId}}",
                "description": "PATCH order status. Provide reason when status is cancelled or rejected."
              }
            },
            {
              "name": "Mark Order Payment Paid",
              "request": {
                "method": "PATCH",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{admin_token}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"transactionId\": \"txn_1234567890\"\n}"
                },
                "url": "{{baseUrl}}/admin/orders/{{orderId}}/payment/paid"
              }
            }
          ]
        }
      ]
    },
