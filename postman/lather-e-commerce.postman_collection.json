  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "John Doe", "type": "text" },
                { "key": "email", "value": "john@example.com", "type": "text" },
                { "key": "password", "value": "password123", "type": "text" },
                { "key": "role", "value": "user", "type": "text" },
                { "key": "profileImage", "type": "file", "src": "", "disabled": true }
              ]
            },
            "url": "{{baseUrl}}/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let jsonData = {};",
                  "try { jsonData = pm.response.json(); } catch (e) {}",
                  "const token = jsonData?.data?.accessToken || jsonData?.accessToken;",
                  "let role = jsonData?.data?.user?.role;",
                  "if (!role && token) {",
                  "  try {",
                  "    const payload = JSON.parse(atob(token.split('.')[1]));",
                  "    role = payload?.role;",
                  "  } catch (e) {}",
                  "}",
                  "if (token) {",
                  "  const tokenKey = role === 'admin' ? 'admin_token' : 'user_token';",
                  "  pm.collectionVariables.set(tokenKey, token);",
                  "  pm.collectionVariables.set('accessToken', token);",
                  "  pm.test('Access token saved from register', function () {",
                  "    pm.expect(token).to.be.a('string').and.not.empty;",
                  "  });",
                  "  pm.test('Token saved by role from register', function () {",
                  "    pm.expect(['admin_token', 'user_token']).to.include(tokenKey);",
                  "  });",
                  "}",
                  "pm.test('Register response is successful', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let jsonData = {};",
                  "try { jsonData = pm.response.json(); } catch (e) {}",
                  "const token = jsonData?.data?.accessToken || jsonData?.accessToken;",
                  "let role = jsonData?.data?.user?.role;",
                  "if (!role && token) {",
                  "  try {",
                  "    const payload = JSON.parse(atob(token.split('.')[1]));",
                  "    role = payload?.role;",
                  "  } catch (e) {}",
                  "}",
                  "if (token) {",
                  "  const tokenKey = role === 'admin' ? 'admin_token' : 'user_token';",
                  "  pm.collectionVariables.set(tokenKey, token);",
                  "  pm.collectionVariables.set('accessToken', token);",
                  "  pm.test('Access token saved from login', function () {",
                  "    pm.expect(token).to.be.a('string').and.not.empty;",
                  "  });",
                  "  pm.test('Token saved by role from login', function () {",
                  "    pm.expect(['admin_token', 'user_token']).to.include(tokenKey);",
                  "  });",
                  "}",
                  "pm.test('Login response is successful', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});"
                ]
              }
            }
          ]
        },
