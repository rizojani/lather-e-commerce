{
  "info": {
    "_postman_id": "e0f4d7b8-d7dc-4ca0-8fcb-2519f90d2f1d",
    "name": "Lather E-Commerce Backend APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Complete API collection for admin and user flows, including auth and forgot password."
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "John Doe", "type": "text" },
                { "key": "email", "value": "john@example.com", "type": "text" },
                { "key": "password", "value": "password123", "type": "text" },
                { "key": "role", "value": "user", "type": "text" },
                { "key": "profileImage", "type": "file", "src": "" }
              ]
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Forgot Password - Send Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\"\n}"
            },
            "url": "{{baseUrl}}/auth/forgot-password/send-token"
          }
        },
        {
          "name": "Forgot Password - Verify Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"token\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/auth/forgot-password/verify-token"
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"token\": \"123456\",\n  \"password\": \"newPassword123\"\n}"
            },
            "url": "{{baseUrl}}/auth/reset-password"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Analytics",
          "item": [
            {
              "name": "Dashboard",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": "{{baseUrl}}/admin/analytics"
              }
            }
          ]
        },
        {
          "name": "Categories",
          "item": [
            {
              "name": "Create Category",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Skincare\",\n  \"description\": \"Skin products\"\n}"
                },
                "url": "{{baseUrl}}/admin/categories"
              }
            },
            {
              "name": "List Categories",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": "{{baseUrl}}/admin/categories"
              }
            }
          ]
        },
        {
          "name": "Products",
          "item": [
            {
              "name": "Create Product",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Face Wash\",\n  \"description\": \"Gentle face wash\",\n  \"price\": 499,\n  \"stock\": 50\n}"
                },
                "url": "{{baseUrl}}/admin/products"
              }
            },
            {
              "name": "Update Product",
              "request": {
                "method": "PATCH",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"price\": 450,\n  \"stock\": 100\n}"
                },
                "url": "{{baseUrl}}/admin/products/{{productId}}"
              }
            },
            {
              "name": "Delete Product",
              "request": {
                "method": "DELETE",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": "{{baseUrl}}/admin/products/{{productId}}"
              }
            }
          ]
        },
        {
          "name": "Orders",
          "item": [
            {
              "name": "List All Orders",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": "{{baseUrl}}/admin/orders"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Products",
          "item": [
            {
              "name": "List Products",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/products?gender=unisex&category=Skincare&size=M&color=Black&price=low_to_high&sort=desc"
              }
            },
            {
              "name": "Latest Products",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/products/latest"
              }
            },
            {
              "name": "Sale Products",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/products/sale"
              }
            },
            {
              "name": "Popular Products",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/products/popular"
              }
            }
          ]
        },
        {
          "name": "Categories",
          "item": [
            {
              "name": "List Categories",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/categories"
              }
            }
          ]
        },
        {
          "name": "Cart",
          "item": [
            {
              "name": "Get Cart",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" },
                  { "key": "sessionId", "value": "{{sessionId}}" }
                ],
                "url": "{{baseUrl}}/cart"
              }
            },
            {
              "name": "Add Or Update Cart Item",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" },
                  { "key": "sessionId", "value": "{{sessionId}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2\n}"
                },
                "url": "{{baseUrl}}/cart/items"
              }
            },
            {
              "name": "Remove Cart Item",
              "request": {
                "method": "DELETE",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" },
                  { "key": "sessionId", "value": "{{sessionId}}" }
                ],
                "url": "{{baseUrl}}/cart/items/{{productId}}"
              }
            }
          ]
        },
        {
          "name": "Orders",
          "item": [
            {
              "name": "Place Order",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" },
                  { "key": "sessionId", "value": "{{sessionId}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"paymentMethod\": \"cod\",\n  \"contactInfo\": {\n    \"fullName\": \"John Doe\",\n    \"phone\": \"+923001234567\",\n    \"email\": \"john@example.com\",\n    \"addressLine1\": \"Street 12, House 44\",\n    \"addressLine2\": \"Near central park\",\n    \"city\": \"Karachi\",\n    \"state\": \"Sindh\",\n    \"country\": \"Pakistan\",\n    \"postalCode\": \"74200\"\n  },\n  \"shippingAddress\": {\n    \"fullName\": \"John Doe\",\n    \"phone\": \"+923001234567\",\n    \"email\": \"john@example.com\",\n    \"addressLine1\": \"Street 12, House 44\",\n    \"addressLine2\": \"Near central park\",\n    \"city\": \"Karachi\",\n    \"state\": \"Sindh\",\n    \"country\": \"Pakistan\",\n    \"postalCode\": \"74200\"\n  },\n  \"billingAddress\": {\n    \"fullName\": \"John Doe\",\n    \"phone\": \"+923001234567\",\n    \"email\": \"john@example.com\",\n    \"addressLine1\": \"Street 12, House 44\",\n    \"addressLine2\": \"Near central park\",\n    \"city\": \"Karachi\",\n    \"state\": \"Sindh\",\n    \"country\": \"Pakistan\",\n    \"postalCode\": \"74200\"\n  }\n}"
                },
                "url": "{{baseUrl}}/orders"
              }
            },
            {
              "name": "My Orders",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" },
                  { "key": "sessionId", "value": "{{sessionId}}" }
                ],
                "url": "{{baseUrl}}/orders/my"
              }
            }
          ]
        },
        {
          "name": "Addresses",
          "item": [
            {
              "name": "Create Address",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"type\": \"shipping\",\n  \"fullName\": \"John Doe\",\n  \"phone\": \"+923001234567\",\n  \"email\": \"john@example.com\",\n  \"addressLine1\": \"Street 12, House 44\",\n  \"addressLine2\": \"Near central park\",\n  \"city\": \"Karachi\",\n  \"state\": \"Sindh\",\n  \"country\": \"Pakistan\",\n  \"postalCode\": \"74200\"\n}"
                },
                "url": "{{baseUrl}}/addresses"
              }
            },
            {
              "name": "List Addresses",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": "{{baseUrl}}/addresses"
              }
            }
          ]
        },
        {
          "name": "Profile",
          "item": [
            {
              "name": "My Profile",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": "{{baseUrl}}/users/me"
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8858/api/v1"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "productId",
      "value": ""
    },
    {
      "key": "sessionId",
      "value": ""
    }
  ]
}
