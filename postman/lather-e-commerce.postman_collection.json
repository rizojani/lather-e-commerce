        {
          "name": "Cart",
          "item": [
            {
              "name": "Get Cart",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{user_token}}" },
                  { "key": "sessionId", "value": "{{sessionId}}" }
                ],
                "url": "{{baseUrl}}/cart",
                "description": "data: parent cart (cartableType user, cartableId = user id or sessionId) and items[] (cartableType cart, cartableId = parent cart id). Each item includes product with medias."
              }
            },
            {
              "name": "Add Or Update Cart Item",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{user_token}}" },
                  { "key": "sessionId", "value": "{{sessionId}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2,\n  \"size\": \"M\",\n  \"color\": \"Black\",\n  \"discount\": 10\n}"
                },
                "url": "{{baseUrl}}/cart/items",
                "description": "Creates user cart row if needed, then upserts line by productId+size+color. Omit size/color for default variant. discount 0-100 optional (else product discount snapshotted when hasDiscount)."
              }
            },
            {
              "name": "Remove Cart Item",
              "request": {
                "method": "DELETE",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{user_token}}" },
                  { "key": "sessionId", "value": "{{sessionId}}" }
