{
  "info": {
    "_postman_id": "e0f4d7b8-d7dc-4ca0-8fcb-2519f90d2f1d",
    "name": "Lather E-Commerce Backend APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Single Postman collection file. Global prefix `/api/v1`.\n\n**baseUrl:** Set the collection variable `baseUrl` to `http://localhost:<PORT>/api/v1` to match your `.env` `PORT` (default in this file follows repo `.env`).\n\n**Category dropdown:** `GET /categories/dropdown` under **Public (no auth)** — no `Authorization` header; usable by guests and any role.\n\nAdmin: products list + filters, multipart create, paginated categories."
  },
  "item": [
    {
      "name": "Public (no auth)",
      "item": [
        {
          "name": "Category dropdown (no token — any role / guest)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/categories/dropdown",
            "description": "Do not send Authorization. Response `data`: `[{ id, title }, ...]` (active categories, A→Z). Same for guests, customers, and admins."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let jsonData = {};",
                  "try { jsonData = pm.response.json(); } catch (e) {}",
                  "const arr = jsonData?.data;",
                  "pm.test('Category dropdown: 200 and data is array', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "  pm.expect(arr).to.be.an('array');",
                  "});",
                  "if (arr && arr.length) {",
                  "  pm.test('Each row has id and title', function () {",
                  "    pm.expect(arr[0]).to.have.keys('id', 'title');",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "John Doe", "type": "text" },
                { "key": "email", "value": "john@example.com", "type": "text" },
                { "key": "password", "value": "password123", "type": "text" },
                { "key": "profileImage", "type": "file", "src": "", "disabled": true }
              ]
            },
            "url": "{{baseUrl}}/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let jsonData = {};",
                  "try { jsonData = pm.response.json(); } catch (e) {}",
                  "const token = jsonData?.data?.accessToken || jsonData?.accessToken;",
                  "let role = jsonData?.data?.user?.role;",
                  "if (!role && token) {",
                  "  try {",
                  "    const payload = JSON.parse(atob(token.split('.')[1]));",
                  "    role = payload?.role;",
                  "  } catch (e) {}",
                  "}",
                  "if (token) {",
                  "  const tokenKey = role === 'admin' ? 'admin_token' : 'user_token';",
                  "  pm.collectionVariables.set(tokenKey, token);",
                  "  pm.test('Access token saved from register', function () {",
                  "    pm.expect(token).to.be.a('string').and.not.empty;",
                  "  });",
                  "  pm.test('Token saved by role from register', function () {",
                  "    pm.expect(['admin_token', 'user_token']).to.include(tokenKey);",
                  "  });",
                  "}",
                  "pm.test('Register response is successful', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let jsonData = {};",
                  "try { jsonData = pm.response.json(); } catch (e) {}",
                  "const token = jsonData?.data?.accessToken || jsonData?.accessToken;",
                  "let role = jsonData?.data?.user?.role;",
                  "if (!role && token) {",
                  "  try {",
                  "    const payload = JSON.parse(atob(token.split('.')[1]));",
                  "    role = payload?.role;",
                  "  } catch (e) {}",
                  "}",
                  "if (token) {",
                  "  const tokenKey = role === 'admin' ? 'admin_token' : 'user_token';",
                  "  pm.collectionVariables.set(tokenKey, token);",
                  "  pm.test('Access token saved from login', function () {",
                  "    pm.expect(token).to.be.a('string').and.not.empty;",
                  "  });",
                  "  pm.test('Token saved by role from login', function () {",
                  "    pm.expect(['admin_token', 'user_token']).to.include(tokenKey);",
                  "  });",
                  "}",
                  "pm.test('Login response is successful', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "const user = jsonData?.data?.user;",
                  "if (user) {",
                  "  pm.test('Login returns user object', function () {",
                  "    pm.expect(user).to.be.an('object');",
                  "    pm.expect(user.email).to.be.a('string');",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
