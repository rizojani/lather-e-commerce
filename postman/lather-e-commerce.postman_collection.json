        {
          "name": "Orders",
          "item": [
            {
              "name": "Place Order",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{user_token}}" },
                  { "key": "sessionId", "value": "{{sessionId}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"paymentMethod\": \"cod\",\n  \"contactInfo\": {\n    \"fullName\": \"John Doe\",\n    \"phone\": \"+923001234567\",\n    \"email\": \"john@example.com\",\n    \"addressLine1\": \"Street 12, House 44\",\n    \"addressLine2\": \"Near central park\",\n    \"city\": \"Karachi\",\n    \"state\": \"Sindh\",\n    \"country\": \"Pakistan\",\n    \"postalCode\": \"74200\"\n  },\n  \"shippingAddress\": {\n    \"fullName\": \"John Doe\",\n    \"phone\": \"+923001234567\",\n    \"email\": \"john@example.com\",\n    \"addressLine1\": \"Street 12, House 44\",\n    \"addressLine2\": \"Near central park\",\n    \"city\": \"Karachi\",\n    \"state\": \"Sindh\",\n    \"country\": \"Pakistan\",\n    \"postalCode\": \"74200\"\n  },\n  \"billingAddress\": {\n    \"fullName\": \"John Doe\",\n    \"phone\": \"+923001234567\",\n    \"email\": \"john@example.com\",\n    \"addressLine1\": \"Street 12, House 44\",\n    \"addressLine2\": \"Near central park\",\n    \"city\": \"Karachi\",\n    \"state\": \"Sindh\",\n    \"country\": \"Pakistan\",\n    \"postalCode\": \"74200\"\n  }\n}"
                },
                "url": "{{baseUrl}}/orders",
                "description": "Creates Order header, then OrderItem rows (`orderItems` collection), then addresses + payment log, clears cart. Response `data` includes order totals plus `items[]` (each: orderId, productId, quantity, unitPrice). Ensure cart has lines before calling."
              }
            },
            {
              "name": "List Orders",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{user_token}}" },
                  { "key": "sessionId", "value": "{{sessionId}}" }
                ],
                "url": "{{baseUrl}}/orders?page=1&limit=10&search=&status=&paymentStatus=&fromDate=&toDate=",
                "description": "Paginated orders for the current owner. Logged-in users are filtered by `userId` from JWT; guests are filtered by `sessionId` header. Empty query values are ignored. Search matches product title/name or category name. Response: { items: OrderResource[], meta }."
              }
            },
            {
              "name": "Get Order By Id",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{user_token}}" },
                  { "key": "sessionId", "value": "{{sessionId}}" }
                ],
                "url": "{{baseUrl}}/orders/{{orderId}}",
                "description": "Same OrderResource shape; each `items[]` entry includes `product` with `medias` (loaded like storefront). Owner-only."
              }
            }
          ]
        },
        {
          "name": "Addresses",
          "item": [
            {
              "name": "Create Address",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{user_token}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"type\": \"shipping\",\n  \"fullName\": \"John Doe\",\n  \"phone\": \"+923001234567\",\n  \"email\": \"john@example.com\",\n  \"addressLine1\": \"Street 12, House 44\",\n  \"addressLine2\": \"Near central park\",\n  \"city\": \"Karachi\",\n  \"state\": \"Sindh\",\n  \"country\": \"Pakistan\",\n  \"postalCode\": \"74200\"\n}"
                },
                "url": "{{baseUrl}}/addresses"
              }
            },
            {
              "name": "List Addresses",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
                "url": "{{baseUrl}}/addresses"
              }
            }
          ]
        },
        {
          "name": "Profile",
          "item": [
            {
              "name": "My Profile",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
                "url": "{{baseUrl}}/users/me"
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
