# Application Configuration
APP_NAME="Trainable"
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Local Database Configuration
MONGODB_URI=mongodb://localhost:27017/trainable

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# Email Configuration (Laravel-style or direct)
# MAIL_HOST=smtppro.zoho.com
# MAIL_PORT=587
# MAIL_ENCRYPTION=tls
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM_ADDRESS=custom-dev@onlinetestingserver.com
# MAIL_FROM_NAME="Alonzo"


MAIL_MAILER=smtp
MAIL_HOST=smtppro.zoho.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="Your App Name"

# Alternative Email Configuration (if not using Laravel-style)
# EMAIL_HOST=smtppro.zoho.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=
# EMAIL_PASS=
# EMAIL_FROM=custom-dev@onlinetestingserver.com

# Stripe Configuration
# Get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# API HTTP timeout (ms). Default 180000. Raise if identity_document uploads hit "timeout being reached (80000ms)".
# STRIPE_HTTP_TIMEOUT_MS=240000
# UAE Connect: set true only for local tests — uploads assets/business_card.png and can exceed HTTP timeouts.
# STRIPE_UAE_ATTACH_ASSETS_DOCUMENT=false
# Optional: overrides BUSINESS_URL for Stripe Connect business_profile.url only
# STRIPE_CONNECT_BUSINESS_PROFILE_URL=https://example.com
# Public app URL sent to Stripe as business_profile.url (if STRIPE_CONNECT_* unset, falls back to APP_URL)
BUSINESS_URL=https://example.com


# Zoom Configuration
ZOOM_API_KEY=your_zoom_api_key
ZOOM_API_SECRET=your_zoom_api_secret
ZOOM_ACCOUNT_ID=your_zoom_account_id


# Firebase / FCM Push Notifications (optional)
# Path to service account JSON (relative to project root or absolute)
GOOGLE_APPLICATION_CREDENTIALS=src/config/trainable-67562-firebase-adminsdk-fbsvc-a471cb6b82.json
